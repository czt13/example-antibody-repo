{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AntibodyEntry",
  "type": "object",
  "required": [
    "antibody_name",
    "uniprot_accession_number",
    "vendor",
    "catalog_number",
    "rrid",
    "validations"
  ],
  "properties": {
    "antibody_name": { "type": "string" },
    "uniprot_accession_number": { "type": "string" },
    "vendor": { "type": "string" },
    "catalog_number": { "type": "string" },
    "rrid": { "type": "string" },
    
    "validations": {
      "type": "array",
      "description": "A flexible list of individual application validations and their data links.",
      "items": {
        "type": "object",
        "required": ["application", "link"],
        "properties": {
          "application": { 
            "type": "string",
            "description": "e.g., Western Blot, IHC, ICC, Flow Cytometry" 
          },
          "link": { 
            "type": "string", 
            "format": "uri",
            "description": "The explicit URL showcasing the validation data for this specific application."
          },
          "notes": { 
            "type": "string",
            "description": "Optional details like tissue type, dilution, or individual researcher name."
          }
        }
      }
    }
  }
}
